{
  "name": "nanocount",
  "version": "1.0.0",
  "private": true,
  "description": "A tiny, privacy-friendly, single-tenant website counter.",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch scripts/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/scripts/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/app.test.ts",
    "check": "npm run typecheck && npm test && npm run build",
    "cf:dev": "wrangler dev",
    "deploy": "wrangler deploy --keep-vars && npm run cf:migrate:remote",
    "cf:deploy": "npm run deploy",
    "cf:migrate:local": "wrangler d1 migrations apply DB --local",
    "cf:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@libsql/client": "^0.17.0",
    "hono": "^4.10.4"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "wrangler": "4.112.0"
  },
  "cloudflare": {
    "bindings": {
      "DB": {
        "description": "Nanocount 的 D1 数据库；一键部署时会自动创建。"
      },
      "ADMIN_PASSWORD": {
        "description": "后台登录密码，请使用至少 12 位的随机字符串。"
      },
      "ALLOWED_HOSTS": {
        "description": "允许统计的域名，多个域名用英文逗号分隔，例如 example.com,*.example.com。"
      }
    }
  }
}
