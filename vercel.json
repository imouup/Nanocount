{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "hono",
  "functions": {
    "src/index.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/nano.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
