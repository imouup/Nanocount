# Required: use a unique password with at least 12 characters.
ADMIN_PASSWORD=replace-with-a-long-random-password

# Comma-separated exact hosts or wildcards (for example: example.com,*.example.com).
# Empty means a browser may only write counts for its own Origin host.
ALLOWED_HOSTS=example.com,*.example.com

# Optional: require this bearer token for public read APIs.
PUBLIC_API_TOKEN=

# Linux/local storage. Relative file paths are created below the project directory.
DATABASE_URL=file:data/nanocount.db

# Vercel: use a remote LibSQL/Turso database instead of DATABASE_URL.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

PORT=3000
SESSION_TTL_HOURS=12
ALLOW_NO_ORIGIN=false
TRUST_PROXY=false

# Optional Docker build base image. Usually leave this unchanged.
NODE_IMAGE=node:22-bookworm-slim
